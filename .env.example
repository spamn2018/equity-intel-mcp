# Example .env for the Equity Intelligence project.
# Copy to .env and fill in real keys. Regenerated 2026-07-07 to match .env.

DATABASE_URL=sqlite:///equity_intel.db
APP_CONTACT_EMAIL=alumnidefi@gmail.com
SEC_USER_AGENT=equity-intelligence-mcp alumnidefi@gmail.com
SEC_RATE_LIMIT_RPS=5.0
SEC_CACHE_DIR=.cache/sec
LOG_LEVEL=info
NEWS_PROVIDER=polygon
PRICE_PROVIDER=polygon
POLYGON_API_KEY=
DEFAULT_TICKERS=POWL,ETN,VST,NEE,ANET,MRVL,AMAT,LRCX,KLAC,MU,EQIX,DLR,IRM,MP,USAR,UUUU,QCOM,ON,CSCO,FSLR
PROHIBITED_TICKERS=AAPL,AA,AKAM,AMZN,APA,ASML,ATO,AVGO,AZN,BABA,BALL,BHP,BK,BNY,BP,BRK.B,BRK-B,CASY,CEG,CF,CIEN,CMI,EME,EXE,FTI,GLNCY,GLW,GOOG,GOOGL,HSBC,HWM,HXSCF,JBL,JNJ,JPM,LLY,META,MPC,MSFT,NSRGY,NTRA,NRG,NVDA,NVS,OVV,PR,PWR,RHHBY,SAN,SHEL,SNDK,SNSSY,SNX,SSNLF,STX,TCEHY,TM,TPR,TSLA,TSM,TTE,V,VLO,VRT,VTRS,WCC,WDC,WMT,XOM

# TradHedge: always-hold positions - ingested for data but excluded from event/signal generation
TRAD_HEDGE_TICKERS=BAC,FLS,CI,STT,WASH,CTVA,CL,WLY,HIG,C

# LLM synthesis - o4-mini via OpenAI API (replaces LM Studio to free GPU)
LLM_PROVIDER=openai
LMSTUDIO_MODEL=o4-mini
OPENAI_API_KEY=

# LLM synthesis timeouts
LLM_TOKEN_IDLE_TIMEOUT_SECONDS=90
LLM_TOTAL_TIMEOUT_SECONDS=120

# Daily brief
DAILY_BRIEF_FORMAT=json
DAILY_BRIEF_DAYS=7
DAILY_BRIEF_CACHE_TTL_SECONDS=86400

# Trading signal generation

# Alpaca paper trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
TRADING_EXECUTION_ENABLED=true
TRADING_REQUIRE_APPROVAL=false
TRADING_MAX_ORDER_NOTIONAL=100.0

# Which broker the trading pipeline (execution.py, auto_rebalance.py,
# close_day_trade_positions.py, dashboard rebalance UI) submits orders
# through. "alpaca" (default) or "etrade". Switching to etrade requires
# .etrade_token.json to already exist -- run etrade_auth.py first.
BROKER_PROVIDER=alpaca
ETRADE_ACCOUNT_ID=913307581
ETRADE_TOKEN_FILE=.etrade_token.json
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
LOCAL_MODEL_BLOCK_AT_OR_ABOVE=3

# Etrade Squeeze bot

# Same-day strategy review auto-apply
STRATEGY_REVIEW_AUTO_APPLY_ENABLED=false
STRATEGY_REVIEW_POLICY_FILE=.cache/strategy_review/auto_applied_policy.json

STRATEGY_REVIEW_RUN_BEFORE_SIGNAL_GENERATION_ENABLED=false
STRATEGY_REVIEW_WINDOW_SESSIONS=20
STRATEGY_REVIEW_BACKTEST_INTERVAL=5m
STRATEGY_REVIEW_ARTIFACT_OUTPUT_DIR=strategy_review_artifacts
