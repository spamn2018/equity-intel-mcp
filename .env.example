# Application identity (required for SEC EDGAR User-Agent header)
APP_NAME=equity-intelligence-mcp
APP_CONTACT_EMAIL=your-email@example.com

# Database
DATABASE_URL=postgresql://localhost/equity_intel

# SEC EDGAR — do not exceed 10 req/s
SEC_USER_AGENT=equity-intelligence-mcp your-email@example.com
SEC_RATE_LIMIT_RPS=8
SEC_CACHE_DIR=.cache/sec
SEC_CACHE_TTL_SECONDS=3600

# News provider (polygon | none)
# Polygon.io = massive.com — same API key covers both news and prices
NEWS_PROVIDER=polygon
POLYGON_API_KEY=your_polygon_api_key_here

# Price provider (polygon | none)
PRICE_PROVIDER=polygon
# PRICE_API_KEY not needed — POLYGON_API_KEY is used for both

# Price sync look-back window in days
PRICE_SYNC_DAYS=90

# MCP
MCP_SERVER_NAME=equity-intelligence
LOG_LEVEL=info

# Default tickers for sync workers
DEFAULT_TICKERS=AAPL,MSFT,NVDA,TSLA,META,GOOGL,AMZN,NFLX

# ── AI Allocation (GPT-4o-mini) ───────────────────────────────────────────────
# Required for the "AI Allocation" tab in the portfolio dashboard.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Daily Brief Scheduler ──────────────────────────────────────────────────────
# Watchlist for the daily brief.
# Leave blank to use DEFAULT_TICKERS above.
DAILY_BRIEF_WATCHLIST=

# Directory where dated brief files are written (created automatically).
DAILY_BRIEF_OUTPUT_DIR=briefs

# Look-back window in calendar days (default 1 = today's catalysts).
DAILY_BRIEF_DAYS=1

# Minimum materiality score [0, 1] to include a catalyst.
DAILY_BRIEF_MIN_MATERIALITY=0.3

# Output format: json | markdown
DAILY_BRIEF_FORMAT=json

# Maximum catalysts per brief.
DAILY_BRIEF_MAX_ITEMS=30
